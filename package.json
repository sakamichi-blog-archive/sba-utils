{
  "name": "@sakamichi-blog-archive/utils",
  "version": "0.3.0",
  "description": "Utils written in JavaScript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakamichi-blog-archive/sba-utils.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    "./blogs": {
      "types": "./dist/blogs.d.mts",
      "import": "./dist/blogs.mjs"
    },
    "./members": {
      "types": "./dist/members.d.mts",
      "import": "./dist/members.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run packcheck && pnpm run license:check",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "license:check": "node scripts/check-licenses.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "packcheck": "publint && pnpm pack --out .out.tgz && attw --profile esm-only .out.tgz && rm .out.tgz",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/node": "^24.13.2",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.18.0"
    }
  },
  "engines": {
    "node": "^24.16.0"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
