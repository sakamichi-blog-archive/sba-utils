{
  "name": "@sakamichi-blog-archive/utils",
  "version": "0.0.1",
  "description": "Utils written in JavaScript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakamichi-blog-archive/sba-utils.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    "./blogs": {
      "types": "./dist/blogs.d.mts",
      "import": "./dist/blogs.mjs"
    },
    "./members": {
      "types": "./dist/members.d.mts",
      "import": "./dist/members.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run packcheck",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "packcheck": "publint && pnpm pack --out .out.tgz && attw --profile esm-only .out.tgz && rm .out.tgz",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@types/node": "^24.13.2",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.18.0"
    }
  },
  "engines": {
    "node": "^24.16.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
