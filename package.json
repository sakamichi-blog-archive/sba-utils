{
  "name": "@sakamichi-blog-archive/utils",
  "version": "0.0.1",
  "description": "Utils written in JavaScript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakamichi-blog-archive/sba-utils.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "exports": {
    "./blogs": {
      "types": "./dist/blogs.d.mts",
      "import": "./dist/blogs.mjs"
    },
    "./members": {
      "types": "./dist/members.d.mts",
      "import": "./dist/members.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run packcheck",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "packcheck": "publint && attw --pack --profile esm-only .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "esprima": "^4.0.1",
    "static-eval": "^2.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/esprima": "^4.0.6",
    "@types/static-eval": "^0.2.34",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.16.0"
    }
  },
  "engines": {
    "node": "^24.16.0"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
