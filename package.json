{
  "name": "@sakamichi-blog-archive/utils",
  "version": "0.0.1",
  "description": "Utils written in JavaScript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakamichi-blog-archive/sba-utils.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "exports": {
    "./blogs": {
      "types": "./dist/blogs.d.mts",
      "import": "./dist/blogs.mjs"
    },
    "./members": {
      "types": "./dist/members.d.mts",
      "import": "./dist/members.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run packcheck",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "packcheck": "publint && attw --pack --profile esm-only .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/node": "^24.13.2",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
    },
    "runtime": {
      "name": "node",
      "version": "^24.16.0"
    }
  },
  "engines": {
    "node": "^24.16.0"
  }
}
